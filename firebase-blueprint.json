{
  "entities": {
    "Account": {
      "title": "Account",
      "description": "Trading account details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "number" },
        "type": { "type": "string", "enum": ["Challenge", "Funded", "Personal", "Failed"] },
        "propFirm": { "type": "string" },
        "initialBalance": { "type": "number" },
        "currentBalance": { "type": "number" },
        "maxBalance": { "type": "number" },
        "profitTarget": { "type": "number" },
        "maxDrawdown": { "type": "number" },
        "consistencyRule": { "type": "number" },
        "commissions": {
          "type": "object",
          "properties": {
            "MNQ": { "type": "number" },
            "NQ": { "type": "number" },
            "ES": { "type": "number" },
            "MES": { "type": "number" },
            "GC": { "type": "number" },
            "MGC": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "size", "type"]
    },
    "Trade": {
      "title": "Trade",
      "description": "Individual trade log",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "accountId": { "type": "string" },
        "strategyId": { "type": "string" },
        "asset": { "type": "string" },
        "direction": { "type": "string", "enum": ["Long", "Short"] },
        "entryPrice": { "type": "number" },
        "stopLoss": { "type": "number" },
        "takeProfit": { "type": "number" },
        "contractSize": { "type": "number" },
        "exits": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "price": { "type": "number" },
              "contracts": { "type": "number" },
              "time": { "type": "string" }
            }
          }
        },
        "pnl": { "type": "number" },
        "commission": { "type": "number" },
        "riskReward": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "beforeImage": { "type": "string" },
        "afterImage": { "type": "string" },
        "entryContext": { "type": "string" },
        "marketRegime": { "type": "string" },
        "fundamentalContext": { "type": "string" },
        "exitLogicFollowed": { "type": "boolean" },
        "psychologyStatus": { "type": "string" },
        "preTradeMindset": { "type": "string" },
        "duringTradeEmotions": { "type": "string" },
        "postTradeReview": { "type": "string" },
        "disciplineScore": { "type": "number" },
        "mistakes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "accountId", "asset", "direction", "entryPrice", "date"]
    },
    "Strategy": {
      "title": "Strategy",
      "description": "Trading strategy definition",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "rules": { "type": "array", "items": { "type": "string" } },
        "setup": {
          "type": "object",
          "properties": {
            "timeframes": { "type": "array", "items": { "type": "string" } },
            "indicators": { "type": "array", "items": { "type": "string" } },
            "confluence": { "type": "array", "items": { "type": "string" } }
          }
        },
        "risk": {
          "type": "object",
          "properties": {
            "maxRiskPerTrade": { "type": "number" },
            "rewardToRisk": { "type": "number" },
            "maxDrawdown": { "type": "number" }
          }
        },
        "psychology": {
          "type": "object",
          "properties": {
            "mindset": { "type": "string" },
            "discipline": { "type": "string" },
            "anxietyTriggers": { "type": "string" },
            "confidenceBoosters": { "type": "string" }
          }
        },
        "dailyLossLimit": { "type": "number" },
        "maxTradesPerDay": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name"]
    }
  },
  "firestore": {
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "Trading accounts"
    },
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Trade logs"
    },
    "/strategies/{strategyId}": {
      "schema": "Strategy",
      "description": "Trading strategies"
    }
  }
}
